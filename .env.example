# ==========================================
# Infinite SpatioTemporal Map - 环境变量模板
# ==========================================
# 使用方法：
#   1. cp .env.example .env
#   2. 把下面的 xxx 替换为你自己的值
#   3. .env 已被 .gitignore 保护，不会进 Git
# ==========================================

# ---------- LLM 网关（推荐：Poe API） ----------
# Poe 提供 OpenAI 兼容端点，一个 key 可用 Claude / GPT / Gemini 所有顶级模型
LLM_BASE_URL=https://api.poe.com/v1/
LLM_API_KEY=xxx-paste-your-poe-key-here-xxx

# 默认模型（可随时切换，推荐值见下方注释）
LLM_MODEL=Claude-Sonnet-4.5
# 备选：
#   Claude-Opus-4.7       质量天花板（关键样本、反思校对用）
#   Claude-Sonnet-4.5     默认主力（质量/额度平衡）
#   GPT-4o                OpenAI
#   Gemini-2.0-Flash      便宜快（扩量用）
#   DeepSeek-V3           国产，中文古文强

# LLM 请求超参
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=5
LLM_TIMEOUT=180

# LLM 缓存目录（加速重复实验，避免重复烧钱）
LLM_CACHE_DIR=.llm_cache

# ---------- 仅用于离线本地测试（不建议常开） ----------
# 设为 true 会返回空桩，完全不调真模型，主要给 CI/测试脚手架用
MOCK_LLM=false
